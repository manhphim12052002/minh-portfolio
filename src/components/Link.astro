---
import { cn } from "@lib/utils";

type Props = {
  href: string;
  external?: boolean;
  underline?: boolean;
}

const { href, external, underline = true, ...rest } = Astro.props;
---

<a
  href={href}
  target={external ? "_blank" : "_self"}
  rel={external ? "noopener noreferrer" : undefined}
  class={cn(
    "inline-block text-current transition-colors duration-base ease-out hover:text-ink dark:hover:text-mist",
    underline && "lumen-underline"
  )}
  {...rest}>
  <slot/>
</a>
