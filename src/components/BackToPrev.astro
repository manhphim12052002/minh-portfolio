---
type Props = {
  href: string;
}

const { href } = Astro.props;
---

<a
  id="back-to-prev"
  href={href}
  class="font-sans text-sm text-fg-2 inline-flex items-center gap-1.5 px-2.5 py-1.5 rounded-md transition-colors duration-fast ease-out hover:bg-accent-soft hover:text-fg-1">
  <span aria-hidden>←</span>
  <slot/>
</a>
