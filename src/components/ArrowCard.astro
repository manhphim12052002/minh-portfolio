---
import type { CollectionEntry } from "astro:content";

type Props = {
  entry: CollectionEntry<"writing"> | CollectionEntry<"projects">;
}

const { entry } = Astro.props;
---

<a
  href={`/${entry.collection}/${entry.slug}`}
  class="group relative block bg-bg-raised rounded-md shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-base ease-out p-6 pr-12 border-0">
  <div class="flex flex-col">
    <div class="font-sans font-semibold text-fg-1 text-lg leading-snug tracking-tight group-hover:text-deep transition-colors duration-base">
      {entry.data.title}
    </div>
    <div class="font-sans text-sm text-fg-2 mt-1.5">
      {entry.data.description}
    </div>
  </div>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    class="absolute top-1/2 right-2 -translate-y-1/2 size-5 stroke-2 fill-none stroke-current group-hover:translate-x-1 transition-transform duration-base ease-out">
    <line x1="5" y1="12" x2="19" y2="12" class="translate-x-3 group-hover:translate-x-0 scale-x-0 group-hover:scale-x-100 transition-transform duration-base ease-in-out" />
    <polyline points="12 5 19 12 12 19" class="-translate-x-1 group-hover:translate-x-0 transition-transform duration-base ease-in-out" />
  </svg>
</a>
