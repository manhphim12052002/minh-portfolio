---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import Eyebrow from "@components/Eyebrow.astro";
import { dateRange } from "@lib/utils";
import { WORK } from "@consts";

const collection = (await getCollection("work"))
  .sort((a, b) => new Date(b.data.dateStart).valueOf() - new Date(a.data.dateStart).valueOf());

const work = await Promise.all(
  collection.map(async (item) => {
    const { Content } = await item.render();
    return { ...item, Content };
  })
);

// Compute year range for eyebrow (handle "Current" as string endDate)
const startYear = work.length
  ? Math.min(...work.map(e => e.data.dateStart.getFullYear()))
  : new Date().getFullYear();
const endYear = work.some(e => typeof e.data.dateEnd === "string")
  ? "Present"
  : Math.max(...work.map(e => (e.data.dateEnd as Date).getFullYear())).toString();
---

<PageLayout title={WORK.TITLE} description={WORK.DESCRIPTION}>
  <Container>
    <!-- Hero -->
    <div class="animate space-y-3 pb-10 border-b border-border">
      <Eyebrow>WORK · {startYear}—{endYear}</Eyebrow>
      <h1 class="font-display font-medium text-4xl md:text-6xl leading-[1.04] tracking-[-0.03em] text-fg-1">
        Where I've shipped.
      </h1>
    </div>

    <!-- Work entries -->
    <ul class="divide-y divide-border">
      {work.map(entry => (
        <li class="animate py-8">
          <div class="flex flex-wrap gap-x-4 gap-y-1 items-baseline mb-4">
            <span class="font-mono text-xs uppercase tracking-[0.1em] text-fg-3">
              {dateRange(entry.data.dateStart, entry.data.dateEnd)}
            </span>
            <span class="font-display font-semibold text-xl text-fg-1">
              {entry.data.company}
            </span>
            <span class="font-sans text-sm text-fg-2">
              {entry.data.role}
            </span>
          </div>
          <article class="lumen-prose">
            <entry.Content />
          </article>
        </li>
      ))}
    </ul>
  </Container>
</PageLayout>
