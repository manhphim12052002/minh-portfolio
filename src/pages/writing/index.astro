---
import { type CollectionEntry, getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import Eyebrow from "@components/Eyebrow.astro";
import FormattedDate from "@components/FormattedDate.astro";
import { BLOG } from "@consts";

const data = (await getCollection("writing"))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

type Acc = {
  [year: string]: CollectionEntry<"writing">[];
}

const posts = data.reduce((acc: Acc, post) => {
  const year = post.data.date.getFullYear().toString();
  if (!acc[year]) {
    acc[year] = [];
  }
  acc[year].push(post);
  return acc;
}, {});

const years = Object.keys(posts).sort((a, b) => parseInt(b) - parseInt(a));
---

<PageLayout title={BLOG.TITLE} description={BLOG.DESCRIPTION}>
  <Container>
    <!-- Hero -->
    <div class="animate space-y-3 pb-10 border-b border-border">
      <Eyebrow>WRITING · {data.length} POSTS</Eyebrow>
      <h1 class="font-display font-medium text-4xl md:text-6xl leading-[1.04] tracking-[-0.03em] text-fg-1">
        Notes, essays, and the occasional talk.
      </h1>
    </div>

    <!-- Posts by year -->
    <div class="space-y-2 pt-4">
      {years.map(year => (
        <section class="animate">
          <div class="font-mono text-xs text-fg-3 tracking-wide pt-8 pb-2">— {year}</div>
          {posts[year].map((post) => (
            <a
              href={`/writing/${post.slug}`}
              class="grid grid-cols-[80px_1fr_auto] gap-5 py-4 border-t border-border items-baseline group hover:pl-2.5 transition-[padding] duration-[220ms] ease-out"
            >
              <FormattedDate date={post.data.date} />
              <div class="font-sans font-semibold text-fg-1 text-base leading-snug tracking-tight group-hover:text-deep transition-colors duration-[220ms]">
                {post.data.title}
              </div>
              <span class="font-sans text-[10px] font-medium uppercase tracking-[0.1em] text-fg-3 px-2 py-1 rounded bg-surface-soft">
                ESSAY
              </span>
            </a>
          ))}
        </section>
      ))}
    </div>
  </Container>
</PageLayout>
